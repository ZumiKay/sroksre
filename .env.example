# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL="postgres://user:password@localhost:5432/sroksre_db"
# Production-only Prisma connection URL (Vercel Postgres / Neon pooled URL)
DATABASE_PROD_POSTGRES_PRISMA_URL=""

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Symmetric encryption key (used for order ID encryption)
KEY="your-32-char-secret-key-here!!!!"

# ─────────────────────────────────────────────
# Authentication (NextAuth)
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# JWT secret (used for custom JWT signing)
JWT_SECRET="your-jwt-secret"

# Google OAuth
GMAIL_CLIENTID=""
GMAIL_CLIENTSECRET=""

# Discord OAuth
DISCORD_CLIENTID=""
DISCORD_CLIENTSECRET=""

# ─────────────────────────────────────────────
# Email (SMTP / Gmail App Password)
# ─────────────────────────────────────────────
EMAIL="your-email@gmail.com"
EMAIL_APPKEY="your-gmail-app-password"

# ─────────────────────────────────────────────
# PayPal
# ─────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_ID="your-paypal-client-id"
PAYPAL_KEY="your-paypal-client-secret"
# Sandbox: https://api-m.sandbox.paypal.com  |  Live: https://api-m.paypal.com
PAYPAL_BASE="https://api-m.sandbox.paypal.com"

# ─────────────────────────────────────────────
# Google reCAPTCHA v2
# ─────────────────────────────────────────────
NEXT_PUBLIC_CAPTCHA_KEY="your-recaptcha-site-key"
CAPTCHA_SECRETKEY="your-recaptcha-secret-key"

# ─────────────────────────────────────────────
# Socket.IO
# ─────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Cron / Webhooks
# ─────────────────────────────────────────────
CRON_SECRET="your-cron-secret"

# ─────────────────────────────────────────────
# Public admin contact info (shown in UI & PDFs)
# ─────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL="admin@sroksre.com"
NEXT_PUBLIC_ADMIN_PHONENUMBER="+85512345678"
NEXT_PUBLIC_ADMIN_IG="https://instagram.com/yourpage"
NEXT_PUBLIC_ADMIN_FB="https://facebook.com/yourpage"

# Low-stock warning threshold (default: 3)
NEXT_PUBLIC_LOWSTOCK="3"

# ─────────────────────────────────────────────
# Seed Configuration (prisma/seed.ts)
# ─────────────────────────────────────────────
ADMIN_EMAIL="admin@sroksre.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_FIRSTNAME="Admin"
ADMIN_LASTNAME="User"
ADMIN_PHONE="+85512345678"

# Set to "true" to seed products/promotions
SEED_PRODUCTS="false"
SEED_PRODUCT_COUNT="20"
SEED_PROMOTIONS="false"
SEED_PROMOTION_COUNT="5"
SEED_PROMOTION_PRODUCT_COUNT="3"

# ─────────────────────────────────────────────
# Dev / Build tools
# ─────────────────────────────────────────────
# Set to "true" to enable @next/bundle-analyzer
ANALYZE="false"
